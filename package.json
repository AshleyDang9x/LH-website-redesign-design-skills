{
  "name": "typeui.sh",
  "version": "0.1.3",
  "description": "Generate design system specifications and style guides as skill files for AI coding providers",
  "main": "dist/cli.js",
  "bin": {
    "typeui.sh": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepack": "npm run build",
    "release:check": "npm run typecheck && npm run test && npm pack --dry-run"
  },
  "keywords": [
    "cli",
    "design-system",
    "skills",
    "ai"
  ],
  "author": "https://bergside.com",
  "license": "LICENSE.md",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://typeui.sh",
  "dependencies": {
    "commander": "^14.0.3",
    "inquirer": "^12.11.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
